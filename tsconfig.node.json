{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"] // Include Node.js types and Vite types
  },
  "include": ["vite.config.ts", "oxfmt.config.ts", "oxlint.config.ts", "build"],
  "exclude": ["node_modules", "dist"]
}
