{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["ESNext", "DOM"],
    "types": ["chrome", "solid-js"],
    "paths": { "@/*": ["./src/*"] }
  },
  "files": ["src/global.d.ts"],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "dist-ff", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
