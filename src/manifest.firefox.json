{
  "manifest_version": 3,
  "name": "Twine Dugger",
  "version": "$version",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },
  "description": "For developers and cheaters in Twine games: See the game state, edit variables, track changes, and debug issues.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>", "file:///*"],
  "devtools_page": "./create-panel.html",
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": ["content-script.js", "content-script.js.map"],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "twinedugger@goctionni.addon",
      "strict_min_version": "150.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
