{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "vp test run --config vitest.stryker.smoke.config.ts src/shared/type-helpers.test.ts --reporter=minimal"
  },
  "mutate": ["src/shared/type-helpers.ts"],
  "reporters": ["clear-text"],
  "coverageAnalysis": "off",
  "concurrency": 1,
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "cleanTempDir": true
}
